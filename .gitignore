.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's system. But for a binary or runable page, you might want to check it in.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if the platform is different, it may not be appropriate.
# Pipfile.lock

# poetry
#   Similarly, poetry.lock contains exact versions, but can be ignored if you want.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, poetry.lock, pdm.lock may be ignored in some cases.
# pdm.lock
.pdm-plugins/
.pdm-build/

# PEP 582; dependency directories created by pipflow/pdm/poetry/etc.
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

